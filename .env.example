# ==================== 掘金量化配置 ====================

# 掘金 Token (必填)
# 从掘金量化官网获取: https://www.myquant.cn/
GM_TOKEN=your_token_here

# 账户ID (可选)
# simulation = 模拟账户
# 或者填写你的实盘账户ID
GM_ACCOUNT_ID=simulation

# 运行模式 (可选)
# live = 实盘/模拟模式
# backtest = 回测模式
GM_RUN_MODE=live

# ==================== 回测配置 (仅回测模式使用) ====================

# 回测开始日期 (YYYY-MM-DD)
BACKTEST_START_DATE=2024-01-01

# 回测结束日期 (YYYY-MM-DD)
BACKTEST_END_DATE=2024-12-31

# 初始资金 (元)
BACKTEST_INITIAL_CASH=1000000
